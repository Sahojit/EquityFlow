# Groq API — get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Tavily web search — get free key at https://app.tavily.com
TAVILY_API_KEY=tvly_your_key_here

# LangFuse observability — get free keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk_your_key_here
LANGFUSE_SECRET_KEY=sk_your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Storage
DATABASE_URL=sqlite:///./alpha_agents.db
CHROMADB_PATH=./chroma_db

# LLM model selection
PRIMARY_MODEL=llama-3.1-8b-instant
FALLBACK_MODEL=llama-3.3-70b-versatile

# Pipeline control
MAX_REVISION_LOOPS=1
